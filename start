#!/bin/bash

# Auto-activate conda environment hummingbot_py310
if [ -z "$CONDA_DEFAULT_ENV" ] || [ "$CONDA_DEFAULT_ENV" != "hummingbot_py310" ]; then
    echo "Activating conda environment: hummingbot_py310"
    eval "$(conda shell.bash hook)"
    conda activate hummingbot_py310
fi

# Export PYTHONPATH
export PYTHONPATH=/Users/handongcui/defi_trading_lab/hummingbot:$PYTHONPATH

PASSWORD=""
FILENAME=""
CONFIG=""

# Argument parsing
while getopts ":p:f:c:" opt; do
  case $opt in
    p)
      PASSWORD="$OPTARG"
      ;;
    f)
      FILENAME="$OPTARG"
      ;;
    c)
      CONFIG="$OPTARG"
      ;;
    \?)
      echo "Invalid option: -$OPTARG" >&2
      exit 1
      ;;
    :)
      echo "Option -$OPTARG requires an argument." >&2
      exit 1
      ;;
  esac
done

# Check if bin/hummingbot_quickstart.py exists
if [[ ! -f bin/hummingbot_quickstart.py ]]; then
    echo "Error: bin/hummingbot_quickstart.py command not found. Make sure you are in the Hummingbot root directory"
    exit 1
fi

# Check if the hummingbot conda environment is activated
if [[ $CONDA_DEFAULT_ENV != "hummingbot" ]]; then
    echo "Activating 'hummingbot' conda environment..."
    source "$(conda info --base)/etc/profile.d/conda.sh"
    conda activate hummingbot
    if [[ $? -ne 0 ]]; then
        echo "Error: Failed to activate 'hummingbot' conda environment."
        exit 1
    fi
fi

# Add current directory to PYTHONPATH to ensure hummingbot module can be imported
export PYTHONPATH="${PWD}:${PYTHONPATH}"

# Build the command to run
CMD="./bin/hummingbot_quickstart.py"
if [[ ! -z "$PASSWORD" ]]; then
    CMD="$CMD -p \"$PASSWORD\""
fi

# Check for valid file extensions
if [[ ! -z "$FILENAME" ]]; then
    if [[ $FILENAME == *.yml || $FILENAME == *.py ]]; then
        CMD="$CMD -f \"$FILENAME\""
    else
        echo "Error: Invalid strategy or script file. File must be a .yml or .py file."
        exit 4
    fi
fi

if [[ ! -z "$CONFIG" ]]; then
    if [[ $CONFIG == *.yml ]]; then
        CMD="$CMD -c \"$CONFIG\""
    else
        echo "Error: Config file must be a .yml file."
        exit 3
    fi
fi

# Execute the command
eval $CMD
